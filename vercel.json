{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/package/build/route.ts": {
      "maxDuration": 120
    },
    "app/api/claims/recommend/route.ts": {
      "maxDuration": 60
    },
    "app/api/image/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/image/edit/route.ts": {
      "maxDuration": 60
    },
    "app/api/similarity/image/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
